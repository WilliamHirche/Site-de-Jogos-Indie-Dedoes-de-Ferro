<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dedões de Ferro — Biblioteca Indie</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #b20000;
    --red-bright: #e00000;
    --dark: #121212;
    --dark2: #1a1a1a;
    --dark3: #222222;
    --gray1: #595454;
    --gray2: #d5d5d5;
    --blue: #338ddd;
    --white: #ffffff;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--white);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: linear-gradient(to bottom, rgba(0,0,0,0.95) 0%, rgba(18,18,18,0.85) 100%);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(178,0,0,0.3);
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 20px;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .logo span { color: var(--red); }
  .logo .gamepad { font-size: 22px; }

  nav {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  nav a {
    color: var(--gray2);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  nav a:hover, nav a.active {
    color: var(--white);
    background: rgba(178,0,0,0.2);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .search-bar {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 6px 12px;
    gap: 6px;
    transition: border-color 0.2s;
  }

  .search-bar:focus-within { border-color: var(--blue); }

  .search-bar input {
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    width: 180px;
  }

  .search-bar input::placeholder { color: var(--gray1); }

  .search-icon { color: var(--gray1); font-size: 13px; }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--gray2);
    color: var(--gray2);
    padding: 6px 14px;
    border-radius: 5px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-outline:hover { border-color: var(--white); color: var(--white); }

  .btn-red {
    background: var(--red);
    border: none;
    color: var(--white);
    padding: 7px 16px;
    border-radius: 5px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-red:hover { background: var(--red-bright); }

  /* ── HERO CAROUSEL ── */
  .hero {
    margin-top: 64px;
    position: relative;
    height: 420px;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.5s ease;
  }

  .carousel-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 80px;
  }

  .slide-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.4);
    transition: transform 8s ease;
  }

  .carousel-slide:hover .slide-bg { transform: scale(1.02); }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(18,18,18,0.95) 0%, rgba(18,18,18,0.5) 50%, transparent 100%);
  }

  .slide-content {
    position: relative;
    z-index: 1;
    max-width: 500px;
  }

  .event-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--red);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .slide-content h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: 48px;
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 10px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.8);
  }

  .slide-content .date {
    color: var(--gray2);
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .slide-content p {
    color: var(--gray2);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .btn-event {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    color: var(--dark);
    padding: 10px 22px;
    border-radius: 5px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    border: none;
    transition: background 0.2s;
  }

  .btn-event:hover { background: var(--gray2); }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--white);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    z-index: 10;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-btn:hover { background: rgba(178,0,0,0.7); }
  .carousel-btn.prev { left: 20px; }
  .carousel-btn.next { right: 20px; }

  .carousel-dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }

  .dot.active { background: var(--red); width: 24px; border-radius: 4px; }

  /* ── CATEGORY ICONS BAR ── */
  .cat-bar {
    background: var(--dark2);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 16px 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .cat-bar::-webkit-scrollbar { display: none; }

  .cat-bar-inner {
    display: flex;
    gap: 8px;
    padding: 0 32px;
    min-width: max-content;
    justify-content: center;
  }

  .cat-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border-radius: 20px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--gray2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .cat-pill:hover, .cat-pill.active {
    background: var(--red);
    border-color: var(--red);
    color: var(--white);
  }

  .cat-pill span { font-size: 15px; }

  /* ── MAIN CONTENT ── */
  main { padding: 40px 32px; }

  /* ── SECTION ROW ── */
  .section { margin-bottom: 48px; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .section-icon {
    width: 4px;
    height: 22px;
    background: var(--red);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .section-header h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .section-header .see-all {
    margin-left: auto;
    color: var(--blue);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .row-wrap {
    position: relative;
  }

  .row {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding-bottom: 6px;
  }

  .row::-webkit-scrollbar { display: none; }

  .row-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.8);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--white);
    width: 36px;
    height: 60px;
    border-radius: 4px;
    font-size: 16px;
    cursor: pointer;
    z-index: 5;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .row-btn:hover { background: rgba(178,0,0,0.8); }
  .row-btn.left { left: -18px; }
  .row-btn.right { right: -18px; }

  /* ── GAME CARD ── */
  .game-card {
    flex-shrink: 0;
    width: 160px;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }

  .game-card:hover {
    transform: scale(1.06) translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.7);
    z-index: 2;
  }

  .game-card .thumb {
    width: 160px;
    height: 220px;
    background: var(--dark3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: var(--gray1);
    position: relative;
    overflow: hidden;
  }

  .game-card .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-placeholder {
    width: 160px;
    height: 220px;
    background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .card-placeholder .soon-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    color: var(--gray1);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .card-placeholder .soon-icon {
    font-size: 28px;
    opacity: 0.3;
  }

  .card-info {
    background: var(--dark3);
    padding: 8px 10px;
  }

  .card-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 3px;
  }

  .card-genre {
    font-size: 10px;
    color: var(--gray1);
    font-weight: 500;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(178,0,0,0.15);
    opacity: 0;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-card:hover .card-overlay { opacity: 1; }

  .play-btn {
    width: 40px;
    height: 40px;
    background: rgba(178,0,0,0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    padding-left: 3px;
  }

  /* ── FAVORITES / SAVED AREA ── */
  .favorites-row {
    display: flex;
    gap: 14px;
  }

  .add-card {
    width: 120px;
    height: 160px;
    background: rgba(255,255,255,0.04);
    border: 2px dashed rgba(255,255,255,0.12);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--gray1);
    font-size: 28px;
  }

  .add-card:hover {
    border-color: var(--red);
    color: var(--red);
    background: rgba(178,0,0,0.08);
  }

  /* ── CATEGORY GRID ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 14px;
  }

  .cat-card {
    background: var(--dark3);
    border-radius: 10px;
    padding: 20px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid transparent;
    aspect-ratio: 1;
  }

  .cat-card:hover {
    background: var(--dark2);
    border-color: var(--red);
    transform: translateY(-3px);
  }

  .cat-card .icon { font-size: 32px; }

  .cat-card .name {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--gray2);
  }

  .cat-card.featured {
    background: linear-gradient(135deg, rgba(178,0,0,0.25) 0%, rgba(178,0,0,0.1) 100%);
    border-color: rgba(178,0,0,0.4);
  }

  .cat-card.featured:hover { border-color: var(--red); }

  /* ── DEVELOPER CARD ── */
  .dev-card {
    flex-shrink: 0;
    width: 280px;
    background: var(--dark3);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s;
  }

  .dev-card:hover {
    transform: translateY(-4px);
    border-color: var(--red);
  }

  .dev-card-header {
    height: 90px;
    background: linear-gradient(135deg, #1a0000 0%, #2d0000 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: var(--red);
    letter-spacing: 2px;
  }

  .dev-card-body { padding: 16px; }

  .dev-card-body h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .dev-card-body p {
    font-size: 12px;
    color: var(--gray2);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .dev-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .dev-tag {
    background: rgba(178,0,0,0.2);
    color: var(--red);
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid rgba(178,0,0,0.3);
  }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    backdrop-filter: blur(6px);
  }

  .modal-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal {
    background: var(--dark2);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 30px 80px rgba(0,0,0,0.8);
    transform: scale(0.95) translateY(20px);
    transition: transform 0.3s;
    scrollbar-width: thin;
    scrollbar-color: var(--red) transparent;
  }

  .modal-overlay.open .modal { transform: scale(1) translateY(0); }

  .modal-top {
    display: flex;
    gap: 0;
    min-height: 360px;
    position: relative;
  }

  .modal-cover {
    width: 280px;
    flex-shrink: 0;
    position: relative;
  }

  .modal-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modal-cover-placeholder {
    width: 280px;
    height: 360px;
    background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 60px;
    opacity: 0.3;
  }

  .modal-info {
    flex: 1;
    padding: 28px 30px;
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, var(--dark2) 0%, var(--dark3) 100%);
  }

  .modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--white);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 5;
  }

  .modal-close:hover { background: var(--red); }

  .modal-badge {
    display: inline-flex;
    gap: 6px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .badge {
    background: rgba(178,0,0,0.2);
    color: var(--red);
    font-size: 10px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    border: 1px solid rgba(178,0,0,0.35);
  }

  .modal-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 30px;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .modal-about {
    font-size: 13px;
    line-height: 1.65;
    color: var(--gray2);
    margin-bottom: 20px;
    flex: 1;
  }

  .modal-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 20px;
    margin-bottom: 20px;
  }

  .meta-item { display: flex; flex-direction: column; gap: 2px; }
  .meta-label { font-size: 10px; color: var(--gray1); text-transform: uppercase; letter-spacing: 0.8px; font-weight: 600; }
  .meta-value { font-size: 13px; color: var(--white); font-weight: 500; }
  .meta-value a { color: var(--blue); text-decoration: none; }
  .meta-value a:hover { text-decoration: underline; }

  .modal-price-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }

  .modal-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 26px;
    font-weight: 900;
    color: var(--white);
  }

  .modal-platform {
    background: rgba(51,141,221,0.15);
    color: var(--blue);
    border: 1px solid rgba(51,141,221,0.3);
    padding: 5px 14px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .modal-actions {
    display: flex;
    gap: 10px;
  }

  .btn-play {
    background: var(--red);
    border: none;
    color: var(--white);
    padding: 10px 24px;
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .btn-play:hover { background: var(--red-bright); }

  .btn-fav {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--white);
    padding: 10px 16px;
    border-radius: 6px;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-fav:hover { border-color: var(--red); color: var(--red); }

  .modal-bottom {
    padding: 20px 28px;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: var(--dark);
  }

  .modal-bottom h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
